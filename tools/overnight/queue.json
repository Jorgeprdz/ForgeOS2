{
  "schema_version": 2,
  "description": "Forge OS deterministic repository-health overnight queue. It performs no implementation and never pushes by default.",
  "valid_job_statuses": [
    "READY",
    "DISABLED"
  ],
  "default_timeout_seconds": 3600,
  "global_gates": [
    {
      "command": "npm test",
      "timeout_seconds": 3600
    },
    {
      "command": "npm run lint",
      "timeout_seconds": 3600
    },
    {
      "command": "npm run scaffold:validate",
      "timeout_seconds": 3600
    }
  ],
  "jobs": [
    {
      "id": "baseline-repository-health",
      "title": "Confirm repository health without changing files",
      "status": "READY",
      "depends_on": [],
      "commands": [
        {
          "command": "npm test",
          "timeout_seconds": 3600
        },
        {
          "command": "npm run lint",
          "timeout_seconds": 3600
        },
        {
          "command": "npm run scaffold:validate",
          "timeout_seconds": 3600
        }
      ],
      "verify": [
        {
          "command": "git diff --check",
          "timeout_seconds": 300
        },
        {
          "command": "test -z \"$(git status --porcelain --untracked-files=all -- ':!.forge/overnight')\"",
          "timeout_seconds": 300
        }
      ],
      "repairs": [],
      "retry_limit": 0,
      "timeout_seconds": 3600,
      "commit_message": "chore(overnight): confirm repository health",
      "push": false,
      "allowed_changed_paths": [],
      "forbidden_changed_paths": [
        "governance/**",
        "adr/**",
        "app.js"
      ]
    }
  ]
}
