{
  "schema": "../contracts/path-policy.schema.json",
  "policy_id": "FORGE_REWRITE_PATH_POLICY_001",
  "allowed_roots": [
    "docs/product/",
    "docs/rewrite/",
    "scaffolds/",
    "tools/termux/rewrite/",
    "platform/",
    "shared/",
    "supabase/"
  ],
  "prohibited_roots": [
    "legacy/",
    "constitutional-rewrite-pack/",
    "nash/",
    "app/",
    "src/legacy/",
    "tmp/",
    "reports/"
  ],
  "prohibited_files": [
    "app.js",
    "index.html",
    "manifest.json",
    "service-worker.js",
    "validation-report.json",
    "migration-report.json"
  ],
  "transient_roots": [
    ".forge/rewrite/",
    "scaffolds/reports/"
  ],
  "notes": [
    "Future stages may generate into platform, shared or supabase only when the stage contract explicitly allows the target path.",
    "Root web entrypoints are prohibited unless a future owner-ratified ADR changes this policy."
  ]
}
