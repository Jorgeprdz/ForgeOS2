{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/constitutional-boundary.schema.json",
  "title": "Forge Constitutional Boundary Registry",
  "type": "object",
  "required": ["schema", "registry_id", "source_documents", "boundaries"],
  "properties": {
    "schema": { "type": "string" },
    "registry_id": { "type": "string" },
    "source_documents": { "type": "array", "items": { "type": "string" } },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source", "path", "section", "description", "scope", "permitted_operations", "prohibited_operations", "affected_components", "severity", "validation_method"],
        "properties": {
          "id": { "type": "string", "pattern": "^BOUND-[A-Z0-9-]+$" },
          "source": { "type": "string" },
          "path": { "type": "string" },
          "section": { "type": "string" },
          "description": { "type": "string", "minLength": 1 },
          "scope": { "type": "array", "items": { "type": "string" } },
          "permitted_operations": { "type": "array", "items": { "type": "string" } },
          "prohibited_operations": { "type": "array", "items": { "type": "string" } },
          "affected_components": { "type": "array", "items": { "type": "string" } },
          "severity": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "validation_method": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
