{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/module-dependencies.schema.json",
  "title": "Forge Module Dependencies",
  "type": "object",
  "required": ["schema", "dependency_model_id", "modules"],
  "properties": {
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "depends_on", "depended_on_by", "dependencies", "contracts", "capabilities", "definition_readiness", "scaffold_readiness", "implementation_readiness", "execution_readiness", "validation_readiness", "promotion_readiness", "blocking_conditions", "build_events_published", "build_events_consumed", "domain_events_published", "domain_events_consumed", "integration_events_published", "integration_events_consumed", "audit_events", "forbidden_events", "evidence_sources", "implementation_locations", "observed_artifacts"]
      }
    }
  }
}
