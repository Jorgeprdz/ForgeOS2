{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/dependency-graph.schema.json",
  "title": "Forge Dependency Graph",
  "type": "object",
  "required": ["schema", "graph_id", "source_artifacts", "topological_order", "active_topological_order", "cycles", "critical_path", "rejected_modules", "deferred_modules", "modules", "event_relationships"],
  "properties": {
    "schema": { "type": "string" },
    "graph_id": { "type": "string" },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "topological_order": { "type": "array", "items": { "type": "string" } },
    "active_topological_order": { "type": "array", "items": { "type": "string" } },
    "cycles": { "type": "array", "items": { "type": "string" } },
    "critical_path": {
      "type": "object",
      "required": ["modules", "edges", "length", "start_module", "end_module", "total_weight"]
    },
    "rejected_modules": { "type": "array", "items": { "type": "string" } },
    "deferred_modules": { "type": "array", "items": { "type": "string" } },
    "event_relationships": { "type": "integer", "minimum": 0 },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "graph_membership", "definition_readiness", "scaffold_readiness", "implementation_readiness", "execution_readiness", "validation_readiness", "promotion_readiness", "build_disposition", "stage_id", "required_contracts", "required_capabilities", "dependencies", "blocking_conditions", "promotion_gate_id", "promotion_gate_state", "promotion_requirements", "rollback_strategy", "build_events_published", "build_events_consumed", "domain_events_published", "domain_events_consumed", "integration_events_published", "integration_events_consumed", "audit_events", "forbidden_events", "evidence_sources", "implementation_locations", "observed_artifacts"],
        "properties": {
          "definition_readiness": { "enum": ["DEFINED", "INCOMPLETE", "BLOCKED", "DEFERRED", "REJECTED"] },
          "scaffold_readiness": { "enum": ["READY", "BLOCKED", "NOT_APPLICABLE"] },
          "implementation_readiness": { "enum": ["READY", "BLOCKED", "DEFERRED", "NOT_APPLICABLE"] },
          "execution_readiness": { "enum": ["ELIGIBLE", "WAITING_FOR_DEPENDENCIES", "WAITING_FOR_DECISION", "WAITING_FOR_EVIDENCE", "DEFERRED", "REJECTED", "COMPLETED"] },
          "validation_readiness": { "enum": ["READY", "BLOCKED", "NOT_APPLICABLE"] },
          "promotion_readiness": { "enum": ["READY", "BLOCKED", "REJECTED", "NOT_APPLICABLE"] },
          "promotion_gate_state": { "enum": ["NOT_EVALUATED", "READY", "BLOCKED", "PASSED", "FAILED", "REJECTED", "NOT_APPLICABLE"] }
        }
      }
    }
  }
}
