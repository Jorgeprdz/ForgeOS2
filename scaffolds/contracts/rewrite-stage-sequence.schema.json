{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/rewrite-stage-sequence.schema.json",
  "title": "Forge Rewrite Stage Sequence",
  "type": "object",
  "required": ["schema", "sequence_id", "status", "stage_id_rule", "tie_breaker", "sequence"],
  "properties": {
    "schema": { "type": "string" },
    "sequence_id": { "type": "string" },
    "status": { "type": "string" },
    "stage_id_rule": { "type": "string" },
    "tie_breaker": { "type": "array", "items": { "type": "string" }, "minItems": 5 },
    "completion_state_source": { "type": "string" },
    "sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage_id", "canonical_order", "dependency_layer", "name", "status", "produces", "consumes", "derived_depends_on_stages", "owner_decisions", "executable_when"],
        "properties": {
          "stage_id": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
          "previous_stage_id": { "type": ["string", "null"] },
          "canonical_order": { "type": "integer", "minimum": 1 },
          "dependency_layer": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "derived_depends_on_stages": { "type": "array", "items": { "type": "string", "pattern": "^SG-[0-9]{3}$" } },
          "produces": { "type": "array", "items": { "type": "string" } },
          "consumes": { "type": "array", "items": { "type": "string" } },
          "owner_decisions": { "type": "array" },
          "executable_when": { "type": "string" },
          "first_consumer_barrier": { "type": "string" }
        }
      }
    },
    "barriers": { "type": "array" }
  }
}
