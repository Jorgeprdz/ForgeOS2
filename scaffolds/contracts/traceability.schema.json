{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/traceability.schema.json",
  "title": "Forge Requirements Traceability Matrix",
  "type": "object",
  "required": ["schema", "matrix_id", "source", "coverage_rule", "entries"],
  "properties": {
    "schema": { "type": "string" },
    "matrix_id": { "type": "string" },
    "source": { "type": "string" },
    "coverage_rule": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability_id", "requirement_id", "constitutional_authority", "boundaries", "adr", "contract", "stage", "scaffold", "validation", "evidence", "acceptance"],
        "properties": {
          "capability_id": { "type": "string", "pattern": "^CAP-[A-Z0-9-]+$" },
          "requirement_id": { "type": "string", "pattern": "^REQ-[A-Z0-9-]+$" },
          "constitutional_authority": { "type": "array", "items": { "type": "string" } },
          "boundaries": { "type": "array", "items": { "type": "string", "pattern": "^BOUND-[A-Z0-9-]+$" } },
          "adr": { "type": "array", "items": { "type": "string" } },
          "contract": { "type": "string" },
          "stage": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
          "scaffold": { "type": "string" },
          "validation": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "string" },
          "acceptance": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
