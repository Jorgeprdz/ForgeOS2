{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/rewrite-execution-plan.schema.json",
  "title": "Forge Rewrite Execution Plan",
  "type": "object",
  "required": ["schema", "execution_plan_id", "generated_from", "selection_algorithm", "stage_id_rule", "active_execution_plan", "deferred_execution_plan", "rejected_modules"],
  "properties": {
    "active_execution_plan": {
      "type": "object",
      "required": ["eligible_now", "eligible_waves", "waiting_for_dependencies", "waiting_for_decisions", "waiting_for_evidence", "modules"],
      "properties": {
        "eligible_now": {
          "type": "object",
          "required": ["SCAFFOLD", "IMPLEMENT", "VALIDATE", "PROMOTE"]
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["current_module", "next_eligible_modules", "next_eligible_wave", "selection_reason", "blocked_alternatives", "completed_dependencies", "pending_dependencies", "required_validations", "required_evidence", "resume_point", "rollback_point", "promotion_gate_id", "promotion_gate_state", "readiness"]
          }
        }
      }
    },
    "deferred_execution_plan": { "type": "array" },
    "rejected_modules": { "type": "array" }
  }
}
