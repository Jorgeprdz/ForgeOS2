{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/rewrite-artifact-graph.schema.json",
  "title": "Forge Rewrite Artifact Graph",
  "type": "object",
  "required": [
    "schema",
    "graph_id",
    "order_source",
    "tie_breaker",
    "stage_id_rule",
    "artifact_completion_model",
    "partial_stage_completion",
    "artifacts",
    "edges",
    "topological_order",
    "waves",
    "cycles",
    "duplicate_producers",
    "authorized_duplicate_producers",
    "missing_producers",
    "terminal_artifacts",
    "historical_compatibility",
    "compatibility_status"
  ],
  "properties": {
    "schema": { "type": "string" },
    "graph_id": { "type": "string" },
    "order_source": { "type": "string", "const": "produces_consumes_topological_sort" },
    "tie_breaker": { "type": "array", "items": { "type": "string" }, "minItems": 5 },
    "stage_id_rule": { "type": "string" },
    "artifact_completion_model": { "type": "string" },
    "partial_stage_completion": { "type": "boolean", "const": true },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact",
          "artifact_id",
          "artifact_type",
          "producer_stage",
          "produced_by",
          "consumer_stages",
          "consumed_by",
          "materialization",
          "version",
          "status",
          "constitution_refs",
          "owner_decision_refs",
          "receipt_template"
        ],
        "properties": {
          "artifact": { "type": "string" },
          "artifact_id": { "type": "string" },
          "artifact_type": {
            "type": "string",
            "enum": ["contract", "schema", "registry", "policy", "decision", "receipt", "read_model", "guard", "evidence", "manifest"]
          },
          "producer_stage": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
          "produced_by": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
          "consumer_stages": { "type": "array", "items": { "type": "string", "pattern": "^SG-[0-9]{3}$" } },
          "consumed_by": { "type": "array", "items": { "type": "string", "pattern": "^SG-[0-9]{3}$" } },
          "materialization": {
            "type": "object",
            "required": ["kind", "paths", "validator", "required"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["file", "manifest_entry", "generated_contract", "receipt", "validated_state", "compatibility_rule", "historical_compatibility"]
              },
              "paths": { "type": "array", "items": { "type": "string" } },
              "validator": { "type": ["string", "null"] },
              "required": { "type": "boolean" }
            }
          },
          "version": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "materialized", "validated", "historical_compatibility"]
          },
          "constitution_refs": { "type": "array", "items": { "type": "string" } },
          "owner_decision_refs": { "type": "array", "items": { "type": "string" } },
          "receipt_template": {
            "type": "object",
            "required": [
              "artifact_id",
              "stage_id",
              "version",
              "materialized_at",
              "evidence",
              "validators",
              "validation_status",
              "content_hash",
              "constitution_refs",
              "decision_refs"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_stage", "to_stage", "artifact", "required_for"]
      }
    },
    "topological_order": { "type": "array", "items": { "type": "string", "pattern": "^SG-[0-9]{3}$" } },
    "waves": { "type": "array" },
    "cycles": { "type": "array" },
    "duplicate_producers": { "type": "array" },
    "authorized_duplicate_producers": { "type": "array" },
    "missing_producers": { "type": "array" },
    "terminal_artifacts": { "type": "array" },
    "historical_compatibility": { "type": "array" },
    "compatibility_status": { "type": "string", "enum": ["PASS", "FAIL"] }
  }
}
