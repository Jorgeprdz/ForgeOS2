{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/rejected-module-denylist.schema.json",
  "title": "Forge Rejected Module Denylist",
  "type": "object",
  "required": ["schema", "denylist_id", "rejected_modules"],
  "properties": {
    "rejected_modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module_id", "capability_ids", "forbidden_events", "validation"]
      }
    }
  }
}
