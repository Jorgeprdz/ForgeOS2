{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/product-capability.schema.json",
  "title": "Forge Product Capability Manifest",
  "type": "object",
  "required": ["schema", "spec_id", "capabilities"],
  "properties": {
    "schema": { "type": "string" },
    "spec_id": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "classification", "users", "problem", "inputs", "outputs", "authority", "boundaries", "dependencies", "acceptance"],
        "properties": {
          "id": { "type": "string", "pattern": "^CAP-[A-Z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "classification": { "enum": ["PRESERVE", "REDESIGN", "DEFER", "REJECT", "REQUIRES_OWNER_DECISION"] },
          "users": { "type": "array", "items": { "type": "string" } },
          "problem": { "type": "string", "minLength": 1 },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "authority": { "type": "array", "items": { "type": "string" } },
          "boundaries": { "type": "array", "items": { "type": "string", "pattern": "^BOUND-[A-Z0-9-]+$" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "acceptance": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
        }
      }
    }
  }
}
