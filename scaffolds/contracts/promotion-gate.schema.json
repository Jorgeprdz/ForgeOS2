{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/promotion-gate.schema.json",
  "title": "Forge Rewrite Promotion Gate",
  "type": "object",
  "required": ["stage", "branch", "main_allowed", "validations_passed", "evidence_present", "authorized_paths_only"],
  "properties": {
    "stage": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
    "branch": { "type": "string" },
    "main_allowed": { "type": "boolean" },
    "validations_passed": { "type": "boolean" },
    "evidence_present": { "type": "boolean" },
    "authorized_paths_only": { "type": "boolean" }
  }
}
