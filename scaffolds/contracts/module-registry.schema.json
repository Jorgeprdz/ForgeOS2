{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/module-registry.schema.json",
  "title": "Forge Module Registry",
  "type": "object",
  "required": ["schema", "registry_id", "modules"],
  "properties": {
    "schema": { "type": "string" },
    "registry_id": { "type": "string" },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "purpose", "owning_domain", "capabilities", "contracts", "constitutional_authority", "adr", "dependencies", "consumers", "evidence_sources", "definition_status", "implementation_status", "disposition", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^MOD-[A-Z0-9-]+$" },
          "definition_status": { "enum": ["CANONICALLY_DEFINED", "CANONICALLY_DEFERRED", "REJECTED"] },
          "implementation_status": { "enum": ["IMPLEMENTED", "PARTIALLY_IMPLEMENTED", "NOT_IMPLEMENTED"] },
          "disposition": { "enum": ["EXISTS_PRESERVE", "EXISTS_REDESIGN", "BUILD_NEW", "DEFER", "REJECT"] }
        }
      }
    }
  }
}
