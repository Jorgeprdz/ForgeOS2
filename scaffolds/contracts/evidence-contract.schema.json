{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/evidence-contract.schema.json",
  "title": "Forge Rewrite Evidence Contract",
  "type": "object",
  "required": ["stage", "generated_at", "operator", "inputs", "outputs", "hashes", "validations", "status"],
  "properties": {
    "stage": { "type": "string", "pattern": "^SG-[0-9]{3}$" },
    "generated_at": { "type": "string" },
    "operator": { "type": "string" },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "hashes": { "type": "object" },
    "validations": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["PASS", "FAIL", "BLOCKED", "ROLLED_BACK"] }
  }
}
