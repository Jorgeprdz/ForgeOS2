{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/path-policy.schema.json",
  "title": "Forge Rewrite Path Policy",
  "type": "object",
  "required": ["policy_id", "allowed_roots", "prohibited_roots", "prohibited_files", "transient_roots"],
  "properties": {
    "policy_id": { "type": "string" },
    "allowed_roots": { "type": "array", "items": { "type": "string" } },
    "prohibited_roots": { "type": "array", "items": { "type": "string" } },
    "prohibited_files": { "type": "array", "items": { "type": "string" } },
    "transient_roots": { "type": "array", "items": { "type": "string" } }
  }
}
