{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/execution-state.schema.json",
  "title": "Forge Termux Rewrite Execution State",
  "type": "object",
  "required": ["current_stage", "completed_stages", "applied_files", "validation_status"],
  "properties": {
    "current_stage": { "type": ["string", "null"] },
    "completed_stages": { "type": "array", "items": { "type": "string" } },
    "applied_files": { "type": "array", "items": { "type": "string" } },
    "validation_status": { "enum": ["NONE", "PASS", "FAIL", "BLOCKED"] }
  }
}
