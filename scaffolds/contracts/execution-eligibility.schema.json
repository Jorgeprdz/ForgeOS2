{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/scaffolds/contracts/execution-eligibility.schema.json",
  "title": "Forge Execution Eligibility",
  "type": "object",
  "required": ["schema", "eligibility_id", "eligible_now", "waiting_for_dependencies", "waiting_for_decisions", "waiting_for_evidence", "deferred", "rejected"],
  "properties": {
    "eligible_now": {
      "type": "object",
      "required": ["SCAFFOLD", "IMPLEMENT", "VALIDATE", "PROMOTE"],
      "properties": {
        "SCAFFOLD": { "type": "array", "items": { "type": "string" } },
        "IMPLEMENT": { "type": "array", "items": { "type": "string" } },
        "VALIDATE": { "type": "array", "items": { "type": "string" } },
        "PROMOTE": { "type": "array", "items": { "type": "string" } }
      }
    },
    "waiting_for_dependencies": { "type": "array", "items": { "type": "string" } },
    "waiting_for_decisions": { "type": "array", "items": { "type": "string" } },
    "waiting_for_evidence": { "type": "array", "items": { "type": "string" } },
    "deferred": { "type": "array", "items": { "type": "string" } },
    "rejected": { "type": "array", "items": { "type": "string" } }
  }
}
