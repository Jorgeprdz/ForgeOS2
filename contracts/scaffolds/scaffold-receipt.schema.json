{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/contracts/scaffolds/scaffold-receipt.schema.json",
  "title": "Forge OS 2.1 Scaffold Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "receiptId",
    "runId",
    "planId",
    "planSha256",
    "scaffold",
    "status",
    "startedAt",
    "finishedAt",
    "approval",
    "environment",
    "outputs",
    "validations",
    "errors",
    "receiptSha256"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "receiptId": {
      "type": "string",
      "pattern": "^SRCPT-[A-Z0-9-]+$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[A-Z0-9-]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^SPLAN-[A-Z0-9-]+$"
    },
    "planSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "scaffold": {
      "type": "string",
      "pattern": "^SCF-[A-Z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "present",
        "actor",
        "approvedAt",
        "planSha256"
      ],
      "properties": {
        "required": {
          "const": true
        },
        "present": {
          "type": "boolean"
        },
        "actor": {
          "type": [
            "string",
            "null"
          ]
        },
        "approvedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "planSha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineVersion",
        "nodeVersion",
        "platform",
        "sourceRef",
        "workingTreeCleanBefore"
      ],
      "properties": {
        "engineVersion": {
          "type": "string"
        },
        "nodeVersion": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "sourceRef": {
          "type": "string",
          "minLength": 7
        },
        "workingTreeCleanBefore": {
          "type": "boolean"
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "operation",
          "sha256",
          "bytes",
          "applied"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001F]).+$"
          },
          "operation": {
            "enum": [
              "CREATE",
              "MODIFY"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "applied": {
            "type": "boolean"
          }
        }
      }
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SCV-[0-9]{3}$"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_APPLICABLE"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receiptSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
