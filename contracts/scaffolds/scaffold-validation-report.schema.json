{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/contracts/scaffolds/scaffold-validation-report.schema.json",
  "title": "Forge OS 2.1 Scaffold Pre-Apply Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "runId",
    "phase",
    "scaffold",
    "createdAt",
    "sourceRef",
    "status",
    "planSha256",
    "renderDigest",
    "staging",
    "validations",
    "deferredValidations",
    "errors",
    "reportSha256"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "reportId": {
      "type": "string",
      "pattern": "^SVRPT-[A-Z0-9-]+$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[A-Z0-9-]+$"
    },
    "phase": {
      "const": "PRE_APPLY"
    },
    "scaffold": {
      "type": "string",
      "pattern": "^SCF-[A-Z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRef": {
      "type": "string",
      "minLength": 7
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "planSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "renderDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "staging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory",
        "directorySha256",
        "fileCount"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "directorySha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "fileCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SCV-[0-9]{3}$"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "DEFERRED"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "deferredValidations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^SCV-[0-9]{3}$"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reportSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
