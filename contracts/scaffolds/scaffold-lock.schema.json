{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/contracts/scaffolds/scaffold-lock.schema.json",
  "title": "Forge OS 2.1 Scaffold Dependency Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scaffold",
    "issuedAt",
    "authoritySha256",
    "definitionSha256",
    "templateSha256",
    "inputSchemaSha256",
    "dependencyLocks",
    "allowedOutputPatterns",
    "lockSha256"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "scaffold": {
      "type": "string",
      "pattern": "^SCF-[A-Z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "authoritySha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "definitionSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "templateSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "inputSchemaSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dependencyLocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "version",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SCF-[A-Z0-9-]+$"
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "allowedOutputPatterns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "lockSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
