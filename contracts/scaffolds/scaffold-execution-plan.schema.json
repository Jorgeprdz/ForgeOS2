{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge-os.local/contracts/scaffolds/scaffold-execution-plan.schema.json",
  "title": "Forge OS 2.1 Scaffold Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "runId",
    "scaffold",
    "mode",
    "createdAt",
    "sourceRef",
    "locks",
    "input",
    "plannedOutputs",
    "conflicts",
    "requiredValidations",
    "approvalRequired",
    "planSha256"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "planId": {
      "type": "string",
      "pattern": "^SPLAN-[A-Z0-9-]+$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[A-Z0-9-]+$"
    },
    "scaffold": {
      "type": "string",
      "pattern": "^SCF-[A-Z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
    },
    "mode": {
      "const": "DRY_RUN"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRef": {
      "type": "string",
      "minLength": 7
    },
    "locks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authoritySha256",
        "registrySha256",
        "definitionSha256",
        "templateSha256",
        "inputSchemaSha256"
      ],
      "properties": {
        "authoritySha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "registrySha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "definitionSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "templateSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "inputSchemaSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001F]).+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "plannedOutputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "outputId",
          "path",
          "operation",
          "conflictState",
          "expectedSha256"
        ],
        "properties": {
          "outputId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001F]).+$"
          },
          "operation": {
            "enum": [
              "CREATE",
              "MODIFY"
            ]
          },
          "conflictState": {
            "enum": [
              "CLEAR_CREATE",
              "CLEAR_MODIFY",
              "CONFLICT_EXISTS",
              "CONFLICT_DIRTY",
              "BLOCKED_PATH",
              "BLOCKED_SYMLINK",
              "BLOCKED_AUTHORITY"
            ]
          },
          "expectedSha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredValidations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^SCV-[0-9]{3}$"
      }
    },
    "approvalRequired": {
      "const": true
    },
    "planSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
